{
  "extends": ["stylelint-config-standard"],
  "plugins": ["stylelint-tailwindcss"],
  "rules": {
    "at-rule-no-unknown": [
      true,
      {
        "ignoreAtRules": [
          "theme",
          "apply",
          "tailwind",
          "components",
          "utilities",
          "screen"
        ]
      }
    ],
    "no-descending-specificity": null,
    "selector-class-pattern": null
  }
}
