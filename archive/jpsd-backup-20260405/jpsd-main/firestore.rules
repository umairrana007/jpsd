rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Baitussalam HQ Security Protocol (v2.4)
    
    function isAdmin() {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // --- USERS & PORTALS ---
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) || isAdmin();
    }

    // --- DONATIONS (TACTICAL ASSETS) ---
    match /donations/{donationId} {
      allow read: if isAdmin() || (request.auth != null && resource.data.userId == request.auth.uid);
      allow create: if request.auth != null;
      allow update, delete: if isAdmin();
    }

    // --- VOLUNTEER MISSIONS ---
    match /missions/{missionId} {
      allow read: if true; // Publicly viewable missions
      allow write: if isAdmin();
    }
    
    match /registrations/{regId} {
      allow read: if isAdmin() || (request.auth != null && resource.data.userId == request.auth.uid);
      allow create: if request.auth != null;
      allow update, delete: if isAdmin();
    }

    // --- ACTIVITY LOGS (HQ INTEL) ---
    match /activityLogs/{logId} {
      allow read: if isAdmin();
      allow write: if request.auth != null; // Automated system logs
    }

    // --- CAUSES ---
    match /causes/{causeId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- GLOBAL CONFIGURATION (LAYOUT & BRANDING) ---
    match /global_config/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
