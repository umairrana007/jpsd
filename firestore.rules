rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Auth Helpers (roles stored lowercase in app, e.g. UserRole.ADMIN = 'admin')
    function isSignedIn() {
      return request.auth != null;
    }

    function callerRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isSignedIn() && callerRole() == 'admin';
    }

    function isCmsStaff() {
      return isSignedIn() && (callerRole() == 'admin' || callerRole() == 'content_manager');
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isPrivilegedRole(r) {
      return r == 'admin' || r == 'content_manager' || r == 'viewer';
    }

    // Public Collections (Read-only for everyone)
    match /causes/{id} {
      allow read: if true;
      allow write: if isCmsStaff();
    }
    
    match /events/{id} {
      allow read: if true;
      allow write: if isCmsStaff();
    }
    
    match /blog_posts/{id} {
      allow read: if true;
      allow write: if isCmsStaff();
    }
    
    match /hero/{id} {
      allow read: if true;
      allow write: if isCmsStaff();
    }

    match /global_config/{id} { allow read: if true; allow write: if isCmsStaff(); }
    match /media/{id} { allow read: if true; allow write: if isCmsStaff(); }
    match /partners/{id} { allow read: if true; allow write: if isCmsStaff(); }
    match /testimonials/{id} { allow read: if true; allow write: if isCmsStaff(); }

    // Dynamic Navigation / Settings / CMS
    match /settings/{id} {
      allow read: if true;
      allow write: if isCmsStaff();
    }
    match /site_config/{id} { allow read: if true; allow write: if isCmsStaff(); }
    match /theme_settings/{id} { allow read: if true; allow write: if isCmsStaff(); }
    match /navigation/{id} { allow read: if true; allow write: if isCmsStaff(); }
    match /homepage_sections/{id} { allow read: if true; allow write: if isCmsStaff(); }
    match /email_templates/{id} { allow read: if true; allow write: if isCmsStaff(); }

    // Users (Private read/write, role protected)
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isSignedIn() && request.auth.uid == userId && 
        (!('role' in request.resource.data) || !isPrivilegedRole(request.resource.data.role));
      allow update: if (isOwner(userId) && !('role' in request.resource.data)) || isAdmin();
    }

    // Donations (Privacy first - CONSOLIDATED BLOCK)
    match /donations/{donationId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid && 
                     request.resource.data.amount is number && request.resource.data.amount > 0;
      allow update, delete: if isAdmin();
    }

    // Login audit trail (append-only for own uid)
    match /login_activity/{id} {
      allow read: if isAdmin();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    // System Collections (Explicit protection)
    match /activity_logs/{logId} {
      allow read: if isAdmin();
      allow write: if isAdmin() || (isSignedIn() && request.resource.data.actorUid == request.auth.uid);
    }
    
    match /cms_analytics/{id} { allow read: if isAdmin(); allow write: if isAdmin(); }
    match /webhook_configs/{id} { allow read, write: if isAdmin(); }

    // Volunteers Collection
    match /volunteers/{volunteerId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    // Default Deny
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
